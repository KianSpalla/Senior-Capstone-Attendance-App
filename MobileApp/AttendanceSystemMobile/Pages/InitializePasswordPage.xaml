<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AttendanceSystemMobile.Pages.InitializePasswordPage"
             Title=""
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

            <!-- Header -->
            <Image Source="eu_logo.png" 
                   Aspect="AspectFit" 
                   HeightRequest="150" 
                   HorizontalOptions="Center"
                   Margin="0,0,0,20"/>

            <Label Text="Set Your Password" 
                   FontSize="28" 
                   FontAttributes="Bold" 
                   TextColor="Black" 
                   HorizontalOptions="Center"/>

            <Label Text="Welcome! You need to set a password before continuing." 
                   FontSize="14" 
                   TextColor="Gray" 
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,20"/>

            <!-- User Info Display -->
            <Border BackgroundColor="#f2f2f2" 
                    Padding="15" 
                    Margin="0,0,0,10">
                <VerticalStackLayout Spacing="5">
                    <Label x:Name="UserNameLabel" 
                           FontSize="16" 
                           FontAttributes="Bold"/>
                    <Label x:Name="UserEnumLabel" 
                           FontSize="14" 
                           TextColor="Gray"/>
                    <Label x:Name="UserEmailLabel" 
                           FontSize="14" 
                           TextColor="Gray"/>
                </VerticalStackLayout>
            </Border>

            <!-- Password Requirements -->
            <Border BackgroundColor="#e3f2fd" 
                    Padding="15"
                    Margin="0,10,0,10">
                <VerticalStackLayout Spacing="5">
                    <Label Text="Password Requirements:" 
                           FontSize="14" 
                           FontAttributes="Bold"
                           TextColor="#1976d2"/>
                    <Label Text="• At least 8 characters long" 
                           FontSize="12" 
                           TextColor="#1976d2"/>
                    <Label Text="• Contains uppercase and lowercase letters" 
                           FontSize="12" 
                           TextColor="#1976d2"/>
                    <Label Text="• Contains at least one number" 
                           FontSize="12" 
                           TextColor="#1976d2"/>
                </VerticalStackLayout>
            </Border>

            <!-- Password Input Fields -->
            <Entry x:Name="NewPasswordEntry" 
                   Placeholder="New Password" 
                   IsPassword="True"
                   TextChanged="OnPasswordTextChanged"/>

            <Entry x:Name="ConfirmPasswordEntry" 
                   Placeholder="Confirm Password" 
                   IsPassword="True"
                   TextChanged="OnPasswordTextChanged"/>

            <!-- Password Strength Indicator -->
            <Label x:Name="PasswordStrengthLabel" 
                   FontSize="12" 
                   IsVisible="False"
                   Margin="0,0,0,10"/>

            <!-- Error/Success Messages -->
            <Label x:Name="ErrorLabel" 
                   TextColor="Red" 
                   IsVisible="False"
                   HorizontalTextAlignment="Center"/>

            <!-- Submit Button -->
            <Button x:Name="SetPasswordButton"
                    Text="Set Password" 
                    Clicked="OnSetPasswordClicked"
                    IsEnabled="False"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    Margin="0,10,0,0"/>

            <!-- Cancel/Logout Link -->
            <Button Text="Cancel / Logout" 
                    Clicked="OnCancelClicked"
                    BackgroundColor="Transparent"
                    TextColor="Gray"
                    FontSize="14"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>