<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AttendanceSystemMobile.Pages.LoginPage"
             Title=""
             BackgroundColor="White">

    <VerticalStackLayout Spacing="20">
        <Image Source="eu_logo.png" 
               Aspect="AspectFit" 
               HeightRequest="200" 
               HorizontalOptions="Center"/>

        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

            <Label Text="Student Login" 
                   FontSize="30" 
                   FontAttributes="Bold" 
                   TextColor="Black" />

            <!-- Step 1: E-Number Entry (Always Visible) -->
            <VerticalStackLayout x:Name="EnumSection" Spacing="15">
                <Entry x:Name="ENumberEntry" 
                       Placeholder="E Number"
                       ReturnType="Next"
                       Completed="OnENumberCompleted"/>

                <Button x:Name="NextButton"
                        Text="Next" 
                        Clicked="OnNextClicked"/>
            </VerticalStackLayout>

            <!-- Step 2: Password Entry (Hidden Initially) -->
            <VerticalStackLayout x:Name="PasswordSection" 
                                 Spacing="15"
                                 IsVisible="False">

                <!-- User Info Display -->
                <Border BackgroundColor="#e3f2fd" 
                        Padding="10"
                        Margin="0,0,0,10">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="👤" FontSize="20"/>
                        <VerticalStackLayout>
                            <Label x:Name="DisplayNameLabel" 
                                   FontSize="14"
                                   FontAttributes="Bold"/>
                            <Label x:Name="DisplayEnumLabel" 
                                   FontSize="12"
                                   TextColor="Gray"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>

                <Entry x:Name="PasswordEntry" 
                       Placeholder="Password" 
                       IsPassword="True"
                       ReturnType="Done"
                       Completed="OnLoginClicked"/>

                <Button x:Name="LoginButton"
                        Text="Login" 
                        Clicked="OnLoginClicked"/>

                <Button Text="← Back" 
                        Clicked="OnBackClicked"
                        BackgroundColor="Transparent"
                        TextColor="Gray"
                        FontSize="14"/>
            </VerticalStackLayout>

            <!-- Loading Indicator -->
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="False"
                               IsVisible="False"
                               Color="#2196F3"/>

            <!-- Error/Info Messages -->
            <Label x:Name="ErrorLabel" 
                   TextColor="Red" 
                   IsVisible="False"
                   HorizontalTextAlignment="Center"/>

        </VerticalStackLayout>
    </VerticalStackLayout>

</ContentPage>