<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AttendanceSystemMobile.Pages.LoginPage"
             Title=""
             BackgroundColor=" White">

    <VerticalStackLayout Spacing="20">
        <Image Source="eu_logo.png" Aspect="AspectFit" HeightRequest="200" HorizontalOptions="Center"/>
        
        <VerticalStackLayout Padding="30" Spacing="30" VerticalOptions="Center">

        <Label Text="Student Login" FontSize="30" FontAttributes="Bold" TextColor="Black" />

        <Entry x:Name="ENumberEntry" Placeholder="E Number" />
        <Entry x:Name="PasswordEntry" Placeholder="Password" IsPassword="True"/>

        <Button Text="Login" Clicked="OnLoginClicked"/>

        <Label x:Name="ErrorLabel" TextColor="Red" IsVisible="False"/>

    </VerticalStackLayout>
    </VerticalStackLayout>

</ContentPage>