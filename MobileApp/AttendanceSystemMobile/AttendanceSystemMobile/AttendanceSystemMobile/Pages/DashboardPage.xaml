<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AttendanceSystemMobile.Pages.DashboardPage"
             Title="">



    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Logout"
                     Order="Primary"
                     Priority="0"
                     Clicked="OnLogoutClicked"/>
    </ContentPage.ToolbarItems>

    <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="15">

           
                <Border BackgroundColor="#f2f2f2" Padding="15">
                    <VerticalStackLayout>
                        <Label x:Name="NameLabel" FontSize="20" FontAttributes="Bold"/>
                        <Label x:Name="ClassLabel"/>
                    </VerticalStackLayout>
                </Border>

              <!--  <Border BackgroundColor="#dff0d8" Padding="15">
                    <Label x:Name="AttendanceLabel"
                       FontSize="18"
                       FontAttributes="Bold"/>
                </Border> -->

            <VerticalStackLayout HorizontalOptions="Center" Spacing="10">

                <GraphicsView x:Name="ProgressCircle"
                  HeightRequest="120"
                  WidthRequest="120" />

                <Label x:Name="AttendanceLabel"
           FontSize="18"
           FontAttributes="Bold"
           HorizontalOptions="Center"/>
            </VerticalStackLayout>



            <Label Text="Upcoming Events"
                   FontSize="18"
                   FontAttributes="Bold"/>

                <CollectionView x:Name="EventsList">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" Margin="5">
                                <VerticalStackLayout>
                                    <Label Text="{Binding EventName}" FontAttributes="Bold"/>
                                    <Label Text="{Binding EventLocation}"/>
                                    <Label Text="{Binding EventTime}"/>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

    </ContentPage>
